  "keyFeatures": [
    "Drop-in NumPy replacement with GPU acceleration via Intel oneAPI/SYCL",
    "Supports Intel, NVIDIA, and AMD GPUs through SYCL backends",
    "Python Array API standard compliance",
    "Optimized with Intel oneMKL for high-performance numerical computing",
    "Submodules for FFT, linear algebra, random number generation, and SciPy-compatible routines",
    "USM (Unified Shared Memory) based array model via dpctl integration",
    "DLPack interoperability for zero-copy tensor sharing",
    "Python 3.10–3.14 support, available via conda, pip, and Intel Distribution for Python"
  ],
  "publicApiSurface": [
